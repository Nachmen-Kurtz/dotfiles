* {
    font-family: 'Google Sans Flex', 'Noto Sans Mono', 'Font Awesome 6 Free', 'Font Awesome 6 Brands', monospace;
    font-size: 15px;
}

window#waybar {
    background-color: transparent;
    border-bottom: none;
}

window#waybar.hidden {
    opacity: 0.15;
}

window#waybar.termite {
    background-color: #1e1e1e;
}

window#waybar.chromium {
    background-color: #111111;
    border: none;
}

button {
    box-shadow: inset 0 -2px transparent;
    border: none;
    border-radius: 0;
}

button:hover {
    background: inherit;
    box-shadow: inset 0 -2px #8a9bb0;
}

/* ── Workspaces ──────────────────────────────────── */

#workspaces button {
    padding: 0 6px;
    background-color: transparent;
    color: #6b7a8d;
    border-radius: 6px;
}

#workspaces button:hover {
    background: rgba(255, 255, 255, 0.05);
    color: #c5cdd9;
}

#workspaces button.focused {
    background-color: #2a2f3a;
    color: #c5cdd9;
    box-shadow: inset 0 -2px #5c7a9e;
}

#workspaces button.urgent {
    background-color: #3d2020;
    color: #cc6666;
}

/* ── Shared module base ──────────────────────────── */

#clock,
#battery,
#cpu,
#memory,
#disk,
#temperature,
#backlight,
#network,
#pulseaudio,
#wireplumber,
#custom-media,
#tray,
#mode,
#idle_inhibitor,
#scratchpad,
#power-profiles-daemon,
#mpd {
    color: #a8b5c4;
    background-color: #1e2229;
    padding: 0 10px;
    margin: 4px 2px;
    border-radius: 6px;
}

#window,
#workspaces {
    margin: 0 4px;
}

.modules-left > widget:first-child > #workspaces {
    margin-left: 0;
}

.modules-right > widget:last-child > #workspaces {
    margin-right: 0;
}

/* ── Audio ───────────────────────────────────────── */

#pulseaudio {
    background-color: #1e2229;
    color: #a8b5c4;
}

#pulseaudio:hover {
    background-color: #252c38;
}

#pulseaudio.muted {
    background-color: #1e2229;
    color: #4a5260;
}

#wireplumber {
    background-color: #1e2229;
    color: #a8b5c4;
}

#wireplumber.muted {
    background-color: #2a1515;
    color: #cc6666;
}

/* ── Tray ────────────────────────────────────────── */

#tray {
    background-color: #1e2229;
}

#tray > .passive {
    -gtk-icon-effect: dim;
}

#tray > .needs-attention {
    -gtk-icon-effect: highlight;
    background-color: #2a1515;
}

/* ── Mode ────────────────────────────────────────── */

#mode {
    background-color: #2a2515;
    color: #c8a96e;
    box-shadow: inset 0 -2px #c8a96e;
}


/* ── Scratchpad ──────────────────────────────────── */

#scratchpad {
    background-color: #1e2229;
    color: #6b7a8d;
}

#scratchpad.empty {
    background-color: transparent;
}

/* ── Language / Keyboard ─────────────────────────── */

#language {
    background-color: #1e2229;
    color: #8ea8a0;
    padding: 0 8px;
    margin: 4px 2px;
}

#keyboard-state {
    background-color: #1e2229;
    color: #6b7a8d;
    padding: 0;
    margin: 4px 2px;
}

#keyboard-state > label {
    padding: 0 6px;
}

#keyboard-state > label.locked {
    color: #c8a96e;
    background: rgba(200, 169, 110, 0.12);
}
